# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# 待域名审核通过后，更新为实际值

# ============================================
# Domain Configuration
# ============================================
NEXT_PUBLIC_APP_URL=https://pdfsum.com

# ============================================
# Database - 待填写 Supabase PostgreSQL
# ============================================
# 在 Supabase 创建项目后获取
# Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.xxx:password@aws-0-xxx.pooler.supabase.com:6543/postgres"

# ============================================
# Clerk Authentication - 待填写生产密钥
# ============================================
# 域名审核通过后，在 Clerk Dashboard 创建生产实例
# Configure > API Keys > Production
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_待填写
CLERK_SECRET_KEY=sk_live_待填写
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================
# DeepSeek AI API - 待填写
# ============================================
# 在 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-prod-待填写

# ============================================
# Stripe Payment (Optional)
# ============================================
# 如果需要付费功能，在 https://dashboard.stripe.com 获取
# STRIPE_SECRET_KEY=sk_live_待填写
# STRIPE_WEBHOOK_SECRET=whsec_待填写
# STRIPE_PRO_PRICE_ID=price_待填写

# ============================================
# App Configuration
# ============================================
NODE_ENV=production
