 # ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# 配置真实的API密钥和Stripe产品ID

# ============================================
# Database - 切换到 Supabase PostgreSQL
# ============================================
# Supabase PostgreSQL (推荐用于生产环境)
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# 本地 SQLite (仅用于开发)
DATABASE_URL="file:./prod.db"

# ============================================
# Clerk Authentication - 请替换为你的真实密钥
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================
# DeepSeek AI API
# ============================================
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# Groq API (免费额度)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# SiliconFlow (备用)
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# Stripe Payment - 多货币配置
# ============================================
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Pro Plan Price IDs (需要先在Stripe创建产品)
STRIPE_PRO_PRICE_USD=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_EUR=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_JPY=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_CNY=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_KRW=price_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# App Configuration
# ============================================
NEXT_PUBLIC_APP_URL=https://pdf-summarizer.vercel.app
NODE_ENV=production
