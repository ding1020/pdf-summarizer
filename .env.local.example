# ===========================================
# PDF Summarizer - 本地配置文件
# ===========================================
# COPY this file to .env.local and fill in your values
# 从 QUICK_SETUP.md 指南获取每个值
# ===========================================

# ============ CLERK (认证) ============
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_CLERK_SECRET_KEY
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============ DATABASE (Supabase PostgreSQL) ============
DATABASE_URL=postgresql://postgres.REPLACE_WITH_PASSWORD@db.REPLACE_WITH_REF.supabase.co:5432/postgres

# ============ AI PROVIDER (Groq - Recommended) ============
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_API_KEY

# ============ PADDLE (支付) ============
# 开发环境 (测试模式)
PADDLE_ENV=sandbox
PADDLE_VENDOR_ID=REPLACE_WITH_YOUR_VENDOR_ID
PADDLE_SECRET_KEY=paddle_test_REPLACE_WITH_YOUR_API_KEY
PADDLE_WEBHOOK_SECRET=paddle_test_REPLACE_WITH_YOUR_WEBHOOK_KEY

# Paddle Price IDs (从 Paddle Dashboard > Catalog > Products 获取)
PADDLE_PRICE_ID=pri_REPLACE_WITH_MONTHLY_PRICE_ID
PADDLE_PRICE_ID_YEARLY=pri_REPLACE_WITH_YEARLY_PRICE_ID

# ============ 应用配置 ============
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# ============ 限流配置 (默认即可) ============
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_FREE=20
RATE_LIMIT_MAX_PRO=60

# ============ 日志 Key (随机生成) ============
LOG_API_KEY=K2DntdhP9YHdzldnGrdxfJK5qGYkhBQ8BthCT2CSdFM=

# ===========================================
# 生产环境变量 (稍后配置)
# ===========================================
# 当你准备好上线时，复制这个文件为 .env.production
# 然后将 sandbox 改为 production，将 paddle_test 改为 paddle_live
