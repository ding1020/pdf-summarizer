# ============================================
# PDF Summary AI - PRODUCTION Configuration
# ============================================
# COPY THIS FILE TO .env.production.local AND FILL IN YOUR VALUES
# DO NOT COMMIT .env.production.local TO VERSION CONTROL!

# ============================================
# 🔧 PADDLE PAYMENT (PRODUCTION)
# ============================================
# Register at: https://vendors.paddle.com
PADDLE_ENVIRONMENT=production

# Get from: Dashboard → Developer Tools → Authentication
PADDLE_SECRET_KEY=pdl_live_xxxxxxxxxxxx

# Create product and get Price ID from:
# Catalog → Products → [Your Product] → Prices
PADDLE_PRICE_ID=pri_xxxxxxxxxxxx     # Monthly price
PADDLE_PRICE_ID_YEARLY=pri_xxxxxxxxxxxx  # Yearly price

# Get from: Notifications → Webhooks → [Your Webhook]
PADDLE_WEBHOOK_SECRET=paddle_live_xxxxxxxxxxxx

# ============================================
# 🔐 CLERK AUTHENTICATION (PRODUCTION)
# ============================================
# Register at: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxx

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================
# 🤖 AI API KEYS
# ============================================
# DeepSeek (Recommended)
# Get from: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx

# ============================================
# 🗄️ DATABASE
# ============================================
# SQLite for production (single server)
# For Vercel serverless, use Turso or PlanetScale
DATABASE_URL="file:./prod.db"

# ============================================
# 🌐 APP CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NODE_ENV=production

# ============================================
# 📧 CONTACT
# ============================================
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@yourdomain.com

# ============================================
# 🔍 SENTRY ERROR MONITORING (OPTIONAL)
# ============================================
# Get from: https://sentry.io/settings/
NEXT_PUBLIC_SENTRY_DSN=
