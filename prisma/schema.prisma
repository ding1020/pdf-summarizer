// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(uuid())
  clerkId              String?   @unique  // Legacy Clerk ID (optional now)
  email                String    @unique
  passwordHash         String?   // Native auth password hash
  firstName            String?
  lastName             String?
  paddleCustomerId     String?   @unique  // Legacy Paddle (kept for data compatibility)
  subscriptionStatus   String    @default("free") // free, pro, past_due, canceled, active
  subscriptionId       String?
  paddleSubscriptionId String?   // Legacy Paddle
  paddlePlanId         String?   // Legacy Paddle
  billingCycle         String?               // monthly, yearly
  subscriptionEndDate  DateTime?
  // ── Creem payment integration ──
  creemCustomerId      String?   @unique
  creemSubscriptionId String?
  creemPriceId         String?
  // ── Password reset ──
  resetToken           String?   @unique
  resetExpires         DateTime?
  // ── Usage tracking ──
  usageCount           Int       @default(0)
  usageResetAt         DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  documents            Document[]
  feedbacks            Feedback[]
  paymentRequests      PaymentRequest[]
}

model Document {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  filename  String
  fileSize  Int
  pageCount Int
  content   String
  summary   String?
  status    String   @default("processing")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status])
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  userName  String?
  userEmail String?
  category  String   @default("general") // general, bug, feature, billing
  message   String
  status    String   @default("open") // open, in_progress, resolved, closed
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PaymentRequest {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  plan       String    // "pro_monthly" | "pro_yearly"
  amount     Int       // amount in cents (e.g. 5900 = ¥59.00)
  channel    String    // "alipay" | "wechat" | "manual"
  txnRef     String?   // last 4 digits of transaction ID from user
  status     String    @default("pending") // pending | approved | rejected
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}
