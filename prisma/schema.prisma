// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id                   String    @id @default(uuid())
  internalId            String?   @unique  @map("clerkId")  // Internal provider-agnostic ID
  email                String    @unique
  passwordHash         String?   // Native auth password hash
  firstName            String?
  lastName             String?
  // ── Email verification ──
  emailVerified        Boolean   @default(false)
  verifyToken          String?   @unique
  verifyExpires        DateTime?
  // ── Active subscription fields ──
  subscriptionStatus   String    @default("free") // free | pro | pro_trial | past_due | canceled
  subscriptionId       String?
  billingCycle         String?               // monthly, yearly
  subscriptionEndDate  DateTime?
  // ── Creem payment integration ──
  creemCustomerId      String?   @unique
  creemSubscriptionId String?
  creemPriceId         String?
  // ── Password reset ──
  resetToken           String?   @unique
  resetExpires         DateTime?
  // ── Usage tracking ──
  usageCount           Int       @default(0)
  usageResetAt         DateTime  @default(now())
  trialUsageTotal      Int       @default(0) // Total summaries during trial (cap enforced)
  // ── Engagement tracking ──
  lastActiveAt         DateTime? // Updated on each authenticated page visit
  lastWinBackSentAt    DateTime? // Prevents duplicate win-back emails
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  documents            Document[]
  feedbacks            Feedback[]
  paymentRequests      PaymentRequest[]
  apiKeys              ApiKey[]

  @@index([subscriptionStatus])

  // ── Data integrity constraints (enforced via SQL migration) ──
  // CHECK (subscriptionStatus IN ('free', 'pro', 'past_due', 'canceled'))
  // CHECK (billingCycle IS NULL OR billingCycle IN ('monthly', 'yearly'))
}

model Document {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename  String
  fileSize  Int
  pageCount Int
  content   String
  summary   String?
  status    String   @default("processing")
  shareId   String?   @unique
  isPublic  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status])

  // ── Data integrity constraints ──
  // CHECK (status IN ('processing', 'completed', 'failed'))
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName  String?
  userEmail String?
  category  String   @default("general") // general, bug, feature, billing
  message   String
  status    String   @default("open") // open, in_progress, resolved, closed
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])

  // ── Data integrity constraints ──
  // CHECK (status IN ('open', 'in_progress', 'resolved', 'closed'))
  // CHECK (category IN ('general', 'bug', 'feature', 'billing'))
}

model PaymentRequest {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       String    // "pro_monthly" | "pro_yearly"
  amount     Int       // amount in cents (e.g. 5900 = ¥59.00)
  channel    String    // "alipay" | "wechat" | "manual"
  txnRef     String?   // last 4 digits of transaction ID from user
  status     String    @default("pending") // pending | approved | rejected
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([createdAt])

  // ── Data integrity constraints ──
  // CHECK (status IN ('pending', 'approved', 'rejected'))
  // CHECK (plan IN ('pro_monthly', 'pro_yearly'))
}

model ApiKey {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String   // human-readable label
  keyHash    String   @unique // SHA-256 hex hash
  keyPrefix  String   // first 8 chars for display (key_xxxx...)
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  revokedAt  DateTime?

  @@index([userId])
  @@index([keyHash])
}

model ProcessedWebhook {
  id          String   @id
  eventType   String   // the Creem event type (subscription.paid, etc.)
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String   // auth, payment, admin, etc.
  resource   String?  // e.g. "User", "PaymentRequest"
  resourceId String?
  details    String?  // JSON-encoded extra data
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
