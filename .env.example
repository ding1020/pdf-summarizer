# =============================================================================
# PDF Summarizer - Environment Variables Configuration Guide
# Copy this file to .env.local and fill in your values
# =============================================================================

# ===========================================
# 1. APPLICATION (Optional - defaults work)
# ===========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# ===========================================
# 2. DATABASE (REQUIRED FOR PRODUCTION)
# ===========================================
# SQLite for local dev, PostgreSQL for production
# 
# Option A: Supabase (Recommended - Free tier available)
#   1. Go to https://supabase.com and create a project
#   2. Go to Settings > Database
#   3. Copy the "Connection string" (URI)
#   4. Replace with: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.XXXX.supabase.co:5432/postgres"

# Option B: Neon (Serverless PostgreSQL - Free tier)
#   1. Go to https://neon.tech and create a project
#   2. Copy the connection string
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/pdf_summarizer"

# Option C: Railway (Pay as you go)
#   1. Go to https://railway.app and create a PostgreSQL database
#   2. Copy the connection string
DATABASE_URL="postgresql://postgres:password@containers-us-west-XX.railway.app:XXXX/railway"

# ===========================================
# 3. AUTHENTICATION - Clerk (REQUIRED)
# ===========================================
#   1. Go to https://dashboard.clerk.com
#   2. Create a new application
#   3. Copy the API keys from the API Keys page
#
# IMPORTANT: Add your domain to Allowed Origins and Redirect URLs in Clerk Dashboard

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ===========================================
# 4. AI PROVIDERS (At least one REQUIRED)
# ===========================================
# 
# Option A: Groq (RECOMMENDED - Free tier, fast)
#   1. Go to https://console.groq.com
#   2. Create API key (free tier: 30 requests/min)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B: DeepSeek (Good value)
#   1. Go to https://platform.deepseek.com
#   2. Create API key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option C: SiliconFlow (Free credits)
#   1. Go to https://www.siliconflow.com
#   2. Create API key
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option D: OpenAI (Paid)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# 5. PADDLE PAYMENT (REQUIRED FOR PAYMENTS)
# ===========================================
#   1. Go to https://paddle.com and sign up as a vendor
#   2. Go to Developer Tools > Authentication
#   3. Copy your Vendor ID and API Key
#
# SANDBOX (Testing):
PADDLE_ENV=sandbox
PADDLE_VENDOR_ID=12345
PADDLE_SECRET_KEY=paddle_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_WEBHOOK_SECRET=paddle_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PRODUCTION (Switch to these when ready):
# PADDLE_ENV=production
# PADDLE_SECRET_KEY=paddle_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PADDLE_WEBHOOK_SECRET=paddle_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# 6. PADDLE PRICE IDS (REQUIRED - Create in Paddle Dashboard)
# ===========================================
#   1. Go to Paddle Dashboard > Catalog > Products
#   2. Create products for Monthly and Yearly plans
#   3. Create prices for each product
#   4. Copy the Price IDs
#
PADDLE_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxx    # Monthly plan
PADDLE_PRICE_ID_YEARLY=pri_xxxxxxxxxxxxxxxxxxxx  # Yearly plan

# ===========================================
# 7. MONITORING (Optional but recommended)
# ===========================================
#
# Sentry (Error tracking - Free tier available)
#   1. Go to https://sentry.io
#   2. Create a project for your Next.js app
#   3. Copy the DSN
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@o123456.ingest.sentry.io/1234567
# SENTRY_DSN=https://xxxxx@o123456.ingest.sentry.io/1234567

# LogRocket (Session replay - Free tier available)
#   1. Go to https://logrocket.com
#   2. Create a project
# NEXT_PUBLIC_LOGROCKET_ID=your_logrocket_id

# ===========================================
# 8. REDIS (Optional - For production rate limiting)
# ===========================================
# Upstash Redis (Serverless, free tier)
#   1. Go to https://upstash.com
#   2. Create a Redis database
#   3. Copy the connection URL
# REDIS_URL=redis://default:xxxx@xxx.upstash.io:6379
# REDIS_ENABLED=true

# ===========================================
# 9. RATE LIMITING (Defaults work for most cases)
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_FREE=20
RATE_LIMIT_MAX_PRO=60

# ===========================================
# 10. BACKUP (Optional - For production)
# ===========================================
# AWS S3 for backups
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_S3_BUCKET=pdf-summarizer-backups
# AWS_REGION=us-east-1
# BACKUP_DIR=./backups
# RETENTION_DAYS=30

# ===========================================
# 11. LOGGING API KEY (Generate a random key)
# ===========================================
# Generate with: openssl rand -hex 32
LOG_API_KEY=generate_a_secure_random_key_here
